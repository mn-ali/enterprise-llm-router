# =============================================================================
# LiteLLM Proxy - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for the providers you use.
# Only the providers you configure in litellm_config.yaml need to be set.
# =============================================================================

# ---------------------------------------------------------------------------
# LiteLLM Proxy
# ---------------------------------------------------------------------------
LITELLM_MASTER_KEY="sk-change-me-to-a-secure-key"

# Admin UI credentials
UI_USERNAME=admin
UI_PASSWORD=change-me-to-a-secure-password

# ---------------------------------------------------------------------------
# PostgreSQL (for spend tracking, virtual keys, team management)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://litellm:litellm_password@db:5432/litellm

# ---------------------------------------------------------------------------
# Azure OpenAI
# ---------------------------------------------------------------------------
AZURE_API_KEY=
AZURE_API_BASE=https://your-resource-name.openai.azure.com/

# ---------------------------------------------------------------------------
# Anthropic
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Huggingface
# ---------------------------------------------------------------------------
HUGGINGFACE_API_KEY=

# ---------------------------------------------------------------------------
# AWS Bedrock
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=us-east-1

# ---------------------------------------------------------------------------
# OpenAI (direct)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Together AI
# ---------------------------------------------------------------------------
TOGETHERAI_API_KEY=

# ---------------------------------------------------------------------------
# Cohere
# ---------------------------------------------------------------------------
COHERE_API_KEY=

# ---------------------------------------------------------------------------
# Replicate
# ---------------------------------------------------------------------------
# REPLICATE_API_KEY=

# ---------------------------------------------------------------------------
# Google Vertex AI
# ---------------------------------------------------------------------------
# VERTEX_PROJECT=
# VERTEX_LOCATION=us-central1

# ---------------------------------------------------------------------------
# Redis (optional - for distributed rate limiting)
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# Logging & Debug
# ---------------------------------------------------------------------------
LITELLM_LOG=INFO
# Options: DEBUG, INFO, None

# ---------------------------------------------------------------------------
# Navy AI
# ---------------------------------------------------------------------------
NAVY_API_KEY=

STORE_MODEL_IN_DB=True
